extends base

block content
  main.main
    .manage-page
      .manage-header
        h2.heading-secondary Manage Bookings
        p.manage-subtitle= `${bookings.length} bookings total`

      if bookings.length === 0
        .manage-empty
          svg.manage-empty__icon
            use(xlink:href='/img/icons.svg#icon-briefcase')
          p.manage-empty__text No bookings found.

      else
        .manage-table
          .manage-table__head
            .manage-table__row
              span.manage-table__cell.manage-table__cell--header.manage-table__cell--grow Tour
              span.manage-table__cell.manage-table__cell--header User
              span.manage-table__cell.manage-table__cell--header Price
              span.manage-table__cell.manage-table__cell--header Date
              span.manage-table__cell.manage-table__cell--header Paid
              span.manage-table__cell.manage-table__cell--header Actions

          .manage-table__body
            each booking in bookings
              .manage-table__row(data-id=`${booking._id}`)
                span.manage-table__cell.manage-table__cell--grow.manage-table__cell--name= booking.tour ? booking.tour.name : 'Deleted Tour'
                span.manage-table__cell= booking.user ? booking.user.name : 'Deleted User'
                span.manage-table__cell= `$${booking.price}`
                span.manage-table__cell= booking.createdAt ? new Date(booking.createdAt).toLocaleDateString('en-us', {year: 'numeric', month: 'short', day: 'numeric'}) : '—'
                span.manage-table__cell
                  if booking.paid
                    span.manage-badge.manage-badge--paid ✓ Paid
                  else
                    span.manage-badge.manage-badge--unpaid ✗ Unpaid
                span.manage-table__cell.manage-table__cell--actions
                  button.manage-btn.manage-btn--delete.btn-delete-resource(data-resource='bookings', data-id=`${booking._id}`, title='Delete')
                    svg: use(xlink:href='/img/icons.svg#icon-trash-2')
