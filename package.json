{
  "name": "natours",
  "version": "2.0.0",
  "description": "Natours - Tour booking application (migrated for Node.js v24)",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "cross-env NODE_ENV=production nodemon server.js",
    "debug": "node --inspect server.js",
    "build:js": "esbuild public/js/index.js --bundle --outfile=public/js/bundle.js --sourcemap --target=es2020 --format=iife --global-name=app",
    "watch:js": "esbuild public/js/index.js --bundle --outfile=public/js/bundle.js --sourcemap --target=es2020 --format=iife --global-name=app --watch",
    "import:data": "node dev-data/data/import-dev-data.js --import",
    "delete:data": "node dev-data/data/import-dev-data.js --delete"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "html-to-text": "^9.0.5",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.14.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.0",
    "pug": "^3.0.4",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "stripe": "^22.0.1",
    "validator": "^13.15.20",
    "xss-filters": "^1.2.7"
  },
  "devDependencies": {
    "eslint": "^9.27.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2"
  }
}
